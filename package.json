{
  "name": "@otterware/workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "check": "pnpm -r --if-present check",
    "dev": "pnpm --filter @otterware/web dev",
    "dev:cli": "pnpm --dir apps/cli dev",
    "deploy": "pnpm --filter @otterware/web deploy",
    "db:migrate:local": "pnpm --dir apps/web db:migrate:local",
    "db:migrate:remote": "pnpm --dir apps/web db:migrate:remote",
    "admin:seed": "pnpm --dir apps/web admin:seed",
    "migrate:legacy": "node scripts/migrate-legacy.mjs",
    "format": "prettier --write .",
    "lint": "oxlint apps packages scripts",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "oxlint": "1.73.0",
    "prettier": "3.9.5",
    "typescript": "7.0.2"
  }
}
