{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "otterware",
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./src/server.ts",
  "assets": {
    "binding": "ASSETS",
    "run_worker_first": true,
  },
  "observability": { "enabled": true },
  "upload_source_maps": true,
  // Give PR/version uploads a shareable *.workers.dev preview URL.
  "preview_urls": true,
  "browser": {
    "binding": "BROWSER",
  },
  "routes": [
    { "pattern": "app.otterware.dev", "custom_domain": true },
    { "pattern": "usercontent.otterware.dev", "custom_domain": true },
  ],
  "vars": {
    "APP_URL": "https://app.otterware.dev",
    "CONTENT_URL": "https://usercontent.otterware.dev",
    "ADMIN_EMAIL": "chris.kafrouni@gmail.com",
    "EMAIL_FROM": "Otterware <noreply@otterware.dev>",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "otterware",
      "database_id": "779560bb-941f-4dd9-9c9e-cb4e4cd5c84d",
      "migrations_dir": "migrations",
    },
  ],
  "r2_buckets": [
    {
      "binding": "ARTIFACTS",
      "bucket_name": "otterware-artifacts",
    },
  ],
}
