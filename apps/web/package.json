{
  "name": "@otterware/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "format": "prettier --write .",
    "check": "prettier --check .",
    "deploy": "pnpm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "admin:seed": "node scripts/seed-admin.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@better-auth/api-key": "1.6.23",
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/vite-plugin": "1.44.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@otterware/contracts": "workspace:*",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/react-devtools": "0.10.8",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.27",
    "@tanstack/router-plugin": "1.168.19",
    "better-auth": "1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "1.24.0",
    "mime-types": "3.0.2",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "^1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260710.1",
    "@tailwindcss/typography": "0.5.20",
    "@tanstack/devtools-vite": "0.8.1",
    "@tanstack/router-cli": "1.167.18",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/mime-types": "3.0.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
